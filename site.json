<!doctype html>
<html lang="sl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Tu-Val CleanSpace urejevalnik</title>
    <link rel="stylesheet" href="editor.css">
  </head>
  <body>
    <header class="editor-header">
      <div>
        <p>Tu-Val CleanSpace</p>
        <h1>Urejevalnik besedil</h1>
      </div>
      <form class="repo-panel" data-login-form>
        <label>
          Uporabnik
          <input data-username type="text" autocomplete="username" placeholder="admin">
        </label>
        <label>
          Geslo
          <input data-password type="password" autocomplete="current-password" placeholder="Admin geslo">
        </label>
        <button class="secondary" type="submit" data-login>Prijava</button>
        <button class="secondary" type="button" data-logout>Odjava</button>
        <button class="primary" type="button" data-save-github>Shrani na GitHub</button>
      </form>
    </header>

    <main class="editor-shell">
      <aside class="editor-sidebar">
        <div class="status" data-status>Izberi stran in klikni besedilo v predogledu.</div>
        <label class="page-select">
          Stran
          <select data-page-select></select>
        </label>
        <div class="field-list" data-field-list></div>
      </aside>

      <section class="preview-panel">
        <div class="preview-toolbar">
          <strong data-current-page>Domov</strong>
          <span>Besedila z modrim robom lahko klikneš in urediš.</span>
        </div>
        <iframe data-preview title="Predogled strani"></iframe>
      </section>
    </main>

    <script src="editor.js"></script>
  </body>
</html>
